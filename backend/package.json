{
  "name": "hackit-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "prestart": "node scripts/checkNodeVersion.js",
    "start": "node src/index.js",
    "predev": "node scripts/checkNodeVersion.js",
    "dev": "nodemon src/index.js",
    "test:smoke": "node scripts/ciSmoke.js",
    "test:e2e-smoke": "node scripts/e2eSmokeStream.js",
    "test": "node --test --import ./test/_setup.mjs",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --import ./test/_setup.mjs",
    "lint": "eslint . --ext .js,.mjs --max-warnings=0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "ws": "^8.20.0",
    "yt-search": "^2.10.8"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "nodemon": "^2.0.22"
  }
}