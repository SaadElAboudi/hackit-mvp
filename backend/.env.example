# Real API testing
MOCK_MODE=false

# YouTube Data API key (comment out to test yt-search fallback)
YT_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# Gemini (enable for reformulation/summary)
USE_GEMINI=true
# Disable verbose reformulation; keep summaries only
USE_GEMINI_REFORMULATION=false
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=models/gemini-2.0-flash-lite-001
GEMINI_TIMEOUT_MS=3500

PORT=3000
