############################################
# Backend .env example (do not commit keys) #
############################################

# Server
PORT=3000

# Modes
# Use MOCK_MODE=true for local dev without external APIs
MOCK_MODE=true
ALLOW_FALLBACK=true

# Gemini usage (optional)
USE_GEMINI=false
USE_GEMINI_REFORMULATION=false
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash-lite-001
GEMINI_TIMEOUT_MS=3500

# YouTube Data API (optional; required for REAL mode)
YT_API_KEY=

# Optional project reference
PROJECT_ID=